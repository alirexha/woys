{
  "manifest_version": 3,
  "name": "vcclient-cachy mic helper",
  "version": "0.0.1",
  "description": "One-click reminder to wire Discord / web apps to the vcclient-mic virtual microphone published by vcclient-cachy.",
  "author": "Alireza Hamayeli",
  "homepage_url": "https://github.com/alirexha/vcclient-cachy",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "vcclient-cachy mic helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [],
  "host_permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "vcclient-cachy@alirexha.github.io",
      "strict_min_version": "115.0"
    }
  },
  "minimum_chrome_version": "111"
}
