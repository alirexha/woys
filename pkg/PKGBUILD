# Maintainer: Alireza Hamayeli <alireza.hmyl@gmail.com>
# woys: Linux-native, CachyOS-optimized real-time voice changer.
# Fork of w-okada/voice-changer (MIT). RVC-only, ONNX Runtime CUDA, PipeWire-native, TUI.

pkgname=woys
pkgver=0.13.0
pkgrel=1
pkgdesc='Linux-native real-time voice changer (RVC + ONNX + PipeWire) — fork of w-okada/voice-changer'
arch=('x86_64')
url='https://github.com/alirexha/woys'
# Mixed license: proprietary (All Rights Reserved) for original work,
# MIT for the upstream-derived src/server/ subtree. See NOTICE.
license=('custom' 'MIT')

# We rely on the user's NVIDIA driver — `cuda` itself is pulled in by Python's
# bundled `nvidia-cuda-runtime-cu12` wheels, so we don't depend on the system
# CUDA package directly.
depends=(
    'python>=3.11'
    'pipewire'
    'pipewire-pulse'
    'pipewire-alsa'
    'nvidia-utils'  # provides libcuda.so for ORT CUDA EP
)
makedepends=(
    'python-pip'
    'python-build'
    'python-installer'
    'python-wheel'
    'python-hatchling'
)
optdepends=(
    'evdev: opt-in global hotkey for engine toggle'
    'pavucontrol: GUI to wire the mic into Discord/CS2 manually'
    'qpwgraph: live PipeWire graph visualizer'
)

# A real release would point at a tag tarball; for the local install path we
# grab the working tree.
source=("$pkgname-$pkgver::git+https://github.com/alirexha/woys.git#tag=v$pkgver")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$pkgname-$pkgver"

    # Install the wheel system-wide.
    python -m installer --destdir="$pkgdir" dist/*.whl

    # Systemd user unit for the persistent woys-mic.
    install -Dm644 pkg/woys-mic.service \
        "$pkgdir/usr/lib/systemd/user/woys-mic.service"

    # License + attribution. Both files are required: LICENSE governs the
    # original work (proprietary), LICENSE.upstream-w-okada governs the
    # src/server/ subtree (MIT). NOTICE establishes the boundary.
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 NOTICE  "$pkgdir/usr/share/licenses/$pkgname/NOTICE"
    install -Dm644 upstream/LICENSE \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE.upstream-w-okada" 2>/dev/null || true

    # Docs.
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    if [ -d docs ]; then
        for f in docs/*.md; do
            install -Dm644 "$f" "$pkgdir/usr/share/doc/$pkgname/$(basename "$f")"
        done
    fi
}

# After install, the user runs:
#   systemctl --user daemon-reload
#   systemctl --user enable --now woys-mic.service
# Or just `woys run` and let it auto-create the mic on first use.
